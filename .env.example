# AxiomID / OpenIdentity agentic service configuration

# Public URLs
AXIOMID_PUBLIC_URL=https://openidentity-md.how.now
HOW_NOW_URL=https://openidentity-md.how.now

# How.now hosting
HOW_NOW_PROJECT=openidentity-md
HOW_NOW_TOKEN=

# Ghost database for agent-native Postgres storage
GHOST_DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
GHOST_BRANCH=main

# Optional fallback deploy target
VERCEL_PROJECT=openidentity-md
VERCEL_TOKEN=
